# Copie para .env (`make env-setup`) e ajuste. O .env é gitignored — nunca
# comite credenciais reais. Em produção, use SSM/secret manager (ver aws/).

# MongoDB
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password
MONGODB_DATABASE=streaming
MONGODB_URI=mongodb://admin:password@mongodb:27017/streaming

# RabbitMQ
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# MinIO / S3
STORAGE_PROVIDER=minio
STORAGE_BUCKET=videos
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123

# Mongo Express (UI) basic auth
MONGO_EXPRESS_USERNAME=admin
MONGO_EXPRESS_PASSWORD=password

# Upload platform (stack local de dev — guard de produção em lib/auth/e2e.ts)
E2E_ADMIN_EMAIL=admin@local.dev

# Server
SERVER_PORT=8080
NODE_ENV=development

# MongoDB Atlas (provisionamento via API). Gere uma service-account key no
# Atlas e cole aqui — NUNCA comite os valores reais.
ATLAS_CLIENT_ID=<atlas-service-account-client-id>
ATLAS_SECRET=<atlas-service-account-secret>
