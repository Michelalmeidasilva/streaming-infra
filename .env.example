# MongoDB Configuration
MONGODB_HOST=mongodb
MONGODB_PORT=27017
MONGODB_USERNAME=admin
MONGODB_PASSWORD=password
MONGODB_DATABASE=streaming
MONGODB_URI=mongodb://admin:password@mongodb:27017/streaming

# RabbitMQ Configuration
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# MinIO / S3 Configuration
STORAGE_PROVIDER=minio
STORAGE_BUCKET=videos
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=password123

# Server Configuration
SERVER_PORT=8080
NODE_ENV=development

# Terraform Production Secrets
# Exportar antes de rodar terraform: set -a && source .env && set +a
export TF_VAR_mongodb_uri="mongodb+srv://user:pass@cluster.mongodb.net/streaming"
export TF_VAR_rabbitmq_url="amqps://user:pass@host.cloudamqp.com/vhost"
export TF_VAR_redis_url="rediss://user:pass@host:6379"
